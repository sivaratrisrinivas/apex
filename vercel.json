{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "bunVersion": "1.x",
  "installCommand": "bun install",
  "buildCommand": "bun run typecheck",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300,
      "includeFiles": "assets/**"
    }
  },
  "rewrites": [
    {
      "source": "/:apexPath*",
      "destination": "/api/index?apexPath=:apexPath*"
    }
  ]
}
