{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "bunVersion": "1.x",
  "installCommand": "bun install",
  "buildCommand": "bun run typecheck",
  "outputDirectory": "public",
  "functions": {
    "api/apex.ts": {
      "maxDuration": 300,
      "includeFiles": "assets/**"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/apex?apexPath="
    },
    {
      "source": "/:apexPath((?!api/).*)",
      "destination": "/api/apex?apexPath=:apexPath"
    }
  ]
}
